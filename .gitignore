# ==== Perilla Mechanical PDF Editor - .gitignore ====

# 构建输出目录（每次编译重新生成，不应提交）
bin/
bin_e2e/
bin_test/
obj/
out/

# 运行时临时文件
*.pdb
*.mdb
*.log

# 依赖包目录（NuGet packages，运行时依赖已提取到 lib/）
packages/

# NuGet 本地工具缓存
.tools/

# 临时 & 调试辅助文件（开发过程中生成，非项目必需）
PDFSharp.dll
Perilla.rsp
compile_test.*

# PowerShell 调试脚本（临时调试产物，可删除）
build.ps1
build_e2e.ps1
build_test.ps1
check*.ps1
inspect*.ps1
install_*.ps1
restore_packages.ps1
download_nuget.ps1
test_build*.ps1
test_compile*.ps1

# OS 生成文件
Thumbs.db
.DS_Store
desktop.ini
